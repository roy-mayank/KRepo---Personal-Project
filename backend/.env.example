ANTHROPIC_API_KEY=your_api_key_here

# Jira
JIRA_DOMAIN=your_domain.atlassian.net
JIRA_ACCESS_TOKEN=your_token_here
JIRA_PROJECT_KEYS=ENG,PROD

# Confluence
CONFLUENCE_SPACE_KEYS=ENG,KB

# Slack
SLACK_BOT_TOKEN=xoxb-your-token
SLACK_CHANNEL_IDS=C01234567,C89012345

# Linear
LINEAR_API_KEY=lin_api_your_key

# Notion OAuth
NOTION_CLIENT_ID=your_notion_oauth_client_id
NOTION_CLIENT_SECRET=your_notion_oauth_client_secret
# Production: https://your-backend.up.railway.app/integrations/notion/callback
NOTION_REDIRECT_URI=http://localhost:8000/integrations/notion/callback

# Google OAuth (Drive, Docs, Sheets, Slides)
GOOGLE_CLIENT_ID=your_google_oauth_client_id
GOOGLE_CLIENT_SECRET=your_google_oauth_client_secret
# Production: https://your-backend.up.railway.app/integrations/google_drive/callback
GOOGLE_REDIRECT_URI=http://localhost:8000/integrations/google_drive/callback

# Integration credentials encryption (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIALS_ENCRYPTION_KEY=your_fernet_key_here

# Parsing
LEMONFOX_API_KEY=your_api_key_here
LLAMA_CLOUD_API_KEY=your_api_key_here


# Langfuse observability
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# Database
# --- Production (Railway) ---
# Add a Postgres + pgvector template, then on the backend service set:
#   DATABASE_URL=${{Postgres.DATABASE_URL}}   # private URL, NOT DATABASE_PUBLIC_URL
#   REQUIRE_PGVECTOR=true
# The backend auto-enables the vector extension and creates tables on startup.
#
# --- Local dev ---
DATABASE_URL=postgresql+asyncpg://postgres:password@127.0.0.1:5432/krepo
REQUIRE_PGVECTOR=true

# CORS — add your Railway frontend URL in production, e.g.:
# CORS_ORIGINS=https://your-frontend.up.railway.app,http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth
FIREBASE_SERVICE_ACCOUNT=base64_encoded_service_account_json
